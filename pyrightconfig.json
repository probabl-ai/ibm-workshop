{
  "include": ["src", "tests", "experiments", "audit"],
  "exclude": [
    "**/__pycache__",
    "**/.pixi",
    "**/scratch",
    "**/reports"
  ],
  "pythonPath": ".venv/bin/python",
  "typeCheckingMode": "basic",
  "reportMissingImports": "warning",
  "reportMissingTypeStubs": false,
  "pythonVersion": "3.11"
}
