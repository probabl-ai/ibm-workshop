{
  "description": "Wisconsin-style breast cancer cytology features (tabular binary classification)",
  "origin": "sklearn.datasets.load_breast_cancer",
  "features": {
    "n_columns": 30,
    "id_column": "sample_id",
    "target_column": "target"
  },
  "splits": {
    "method": "train_test_split",
    "random_state": 42,
    "test_size": 119,
    "public": {
      "file": "public.csv",
      "n_rows": 450,
      "target_counts": {
        "0": 136,
        "1": 314
      }
    },
    "test": {
      "features_file": "test/features.csv",
      "labels_file": "test/labels.csv",
      "n_rows": 119,
      "target_counts": {
        "0": 40,
        "1": 79
      }
    }
  }
}
